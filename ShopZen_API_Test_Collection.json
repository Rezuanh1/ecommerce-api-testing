          "name": "TC-API-001 | POST Register - Valid Credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has id and token', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('id');",
                  "    pm.expect(json).to.have.property('token');",
                  "});",
                  "pm.test('Response time is less than 2000ms', function() {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "var json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('auth_token', json.token); }",
                  "if (json.id) { pm.collectionVariables.set('user_id', json.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
